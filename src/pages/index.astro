---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;

const processItems = [
  {
    image: `${base}/assets/1. early-experimentation.jpeg`,
    title: "Early Experimentation",
    alt: "Prototype disc fitted with vertical wooden dowels during an early studio sound and form experiment",
    caption:
      "In an early studio session, Tate tests the relationship between sound and spatial form using a prototype disc fitted with vertical wooden dowels. This first iteration explored the placement of sound-emitting elements and laid the conceptual groundwork for Drift's kinetic structure."
  },
  {
    image: `${base}/assets/2. cutting-rings.jpeg`,
    title: "Cutting the Rings",
    alt: "Large plywood rings being routed in the workshop",
    caption:
      "Tim shapes large circular rings from plywood in his workshop, using a router to cut the concentric forms that would become Drift's signature visual element. The rings — some nearly four feet across — required precision cutting across multiple sessions."
  },
  {
    image: `${base}/assets/3. the-rings.jpeg`,
    title: "The Rings",
    alt: "Freshly cut concentric plywood rings nested within the original sheet",
    caption:
      "The freshly cut rings, still nested within the plywood sheet from which they were routed, photographed outside the workshop. This image captures both the material process and the emerging visual language of the work: concentric circles that cast dramatic shadows in gallery space."
  },
  {
    image: `${base}/assets/4. more-ring-process.jpeg`,
    title: "Rings in Space",
    alt: "Suspended wooden rings casting concentric shadows during an early lighting test",
    caption:
      "An early suspension test: wooden rings hung from wires in a darkened space, casting concentric shadow circles on the wall behind them. Testing how the rings interact with light became central to developing Drift's visual experience."
  },
  {
    image: `${base}/assets/5. cutting-legs.png`,
    title: "Cutting the Legs",
    alt: "Wooden dowels being cut to size for the hanging interior structure",
    caption:
      "Tim cuts the wooden dowels that will hang vertically within Drift's structure. Each rod is sized to precise dimensions to create the layered visual rhythm of the final installation."
  },
  {
    image: `${base}/assets/6. diagramming-rotation.jpeg`,
    title: "Diagramming the Rotation",
    alt: "Digital overhead schematic of the base motor and belt-drive system",
    caption:
      "A digital schematic of the base's motor and belt-drive system, viewed from above. Tim developed this diagram to work out servo motor placement, pulley routing, and mounting points — the engineering logic that will make the sculpture move."
  },
  {
    image: `${base}/assets/7. building-the-base.jpeg`,
    title: "Building the Base",
    alt: "Large circular base framework being glued and clamped together",
    caption:
      "Tim glues and clamps the radial rib framework of the large circular base — a wagon-wheel structure that will house the drive mechanism and anchor the hanging vertical elements above."
  },
  {
    image: `${base}/assets/8. building-the-base-2.jpeg`,
    title: "The Bent Skirt",
    alt: "Curved plywood exterior band beside the assembled base framework",
    caption:
      "The curved exterior band — a strip of plywood bent into a full circle — sits beside the assembled rib framework. Getting the curve to hold cleanly required careful wood preparation and extended clamping time."
  },
  {
    image: `${base}/assets/9. building the base-3.jpeg`,
    title: "Securing the Base",
    alt: "Fasteners being drilled into the assembled circular base while clamps remain in place",
    caption:
      "Tim drills fasteners into the assembled base, with glue and bar clamps still in place. The structure is nearly five feet in diameter, built to support the full weight of the kinetic installation."
  },
  {
    image: `${base}/assets/9.5 the base.jpeg`,
    title: "The Base Complete",
    alt: "Finished circular plywood base with white-painted edge ready for motor installation",
    caption:
      "The finished base: a smooth plywood disc with a clean white-painted edge, standing nearly five feet across. Structurally complete, it is now ready to receive the motor and electronics."
  },
  {
    image: `${base}/assets/10. spinning mechanism.jpeg`,
    title: "Electronics and Motion",
    alt: "Servo motors, brackets, wiring, and a wooden bearing housing laid out for assembly",
    caption:
      "Tate lays out the servo motors, brackets, and control wiring that will drive Drift's rotation. The stacked wooden bearing housing at center, surrounded by motor components, represents the integration of Carson's electronics and software work with Murray's woodcraft."
  },
  {
    image: `${base}/assets/11. full-design-diagram.png`,
    title: "Full Installation Design",
    alt: "Scale study rendering showing the installation footprint relative to a standing viewer",
    caption:
      "Tim's scale study for the Drift installation, created to explore the work's footprint and proportions in relation to a viewer's body. The fabrication is ongoing — this rendering helps calibrate the physical form as the components come together."
  }
];

const theoryItems = [
  {
    title: "Embodied perception",
    body:
      "The installation asks visitors to register shifts in light, scale, and proximity before they convert them into interpretation."
  },
  {
    title: "Index of making",
    body:
      "Tool marks, seams, and tests are not hidden. They signal that the piece is a live record of decisions, revisions, and contingencies."
  },
  {
    title: "Threshold space",
    body:
      "Rather than behaving like a singular image, the work operates as an atmosphere that visitors enter, traverse, and co-produce."
  }
];

const visitItems = [
  {
    title: "Location",
    body: "Install venue name here, with floor or room details for wayfinding."
  },
  {
    title: "Duration",
    body: "Ideal dwell time: 2 to 5 minutes for a quick pass, longer for close reading."
  },
  {
    title: "Accessibility",
    body: "Add seating, lighting, caption, and sound-level notes if the installation uses them."
  },
  {
    title: "Credits",
    body: "Artist, fabricators, collaborators, venue support, and production acknowledgements."
  }
];
---

<BaseLayout
  title="Drift Installation Guide"
  description="A QR-friendly microsite for visitors to learn about the installation's process and theoretical basis."
>
  <div class="page-shell">
    <header class="site-header">
      <div>
        <p class="site-kicker">Installation guide</p>
        <p class="site-subtitle">A QR-friendly field guide to process, theory, and encounter.</p>
      </div>
      <nav class="section-nav" aria-label="Page sections">
        <a class="section-link" href="#overview">Overview</a>
        <a class="section-link" href="#process">Process</a>
        <a class="section-link" href="#theory">Theory</a>
        <a class="section-link" href="#visit">Visit</a>
      </nav>
    </header>

    <main>
      <section class="hero-grid" id="overview">
        <article class="intro-panel" data-reveal>
          <div>
            <span class="eyebrow">Field Guide</span>
            <h1 class="hero-title">A field guide to the installation.</h1>
          </div>
          <p class="intro-copy">
            This site is designed for visitors who scan the QR code while standing with the work.
            It offers a concise reading path through the installation's process, material logic,
            and theoretical grounding without losing the editorial calm of the original concept.
          </p>
          <div class="meta-row">
            <span>Process archive</span>
            <span>Theory notes</span>
            <span>Visit cues</span>
          </div>
        </article>

        <div class="stack">
          <article class="note-card" data-reveal>
            <strong>What visitors learn here</strong>
            <p>
              How the piece was built, how light and material behave inside it, and why the
              installation is grounded in embodied perception rather than passive viewing.
            </p>
          </article>
          <article class="note-card" data-reveal>
            <strong>How to customize it</strong>
            <p>
              Replace the placeholder process images, tune the wall text to match your actual piece,
              and swap in venue-specific notes for access, credits, and logistics.
            </p>
          </article>
          <article class="note-card" data-reveal>
            <strong>Why this direction</strong>
            <p>
              It keeps the Cargo-like editorial rhythm from Version 1 while giving you a cleaner
              structure for long-term updates inside Astro.
            </p>
          </article>
        </div>
      </section>

      <section class="section-grid" id="process">
        <div data-reveal>
          <span class="eyebrow">Process</span>
          <h2 class="section-title">How the work came together.</h2>
          <div class="manifesto">
            <p>
              The installation evolved through repeated cycles of material testing, on-site
              calibration, and audience movement studies. Each revision asked the same question:
              how can the work remain visibly constructed while still producing a transformed
              spatial experience?
            </p>
          </div>
        </div>

        <div class="image-rail">
          {
            processItems.map((item) => (
              <figure class="image-card" data-reveal>
                <img src={item.image} alt={item.alt} />
                <figcaption class="image-caption">
                  <strong>{item.title}</strong>
                  <span>{item.caption}</span>
                </figcaption>
              </figure>
            ))
          }
        </div>
      </section>

      <section class="section-grid" id="theory">
        <div class="theory-stack">
          <div data-reveal>
            <span class="eyebrow">Theoretical Basis</span>
            <h2 class="section-title">The work is about relation, not just objecthood.</h2>
          </div>
          <div class="manifesto" data-reveal>
            <ul class="bullet-list">
              <li>
                Phenomenology: meaning emerges through the viewer's moving body, distance, and
                orientation in space.
              </li>
              <li>
                Material memory: surfaces hold evidence of making, so process remains visible as
                part of the finished piece.
              </li>
              <li>
                Social choreography: the installation quietly organizes encounter, spacing, and
                collective attention.
              </li>
            </ul>
          </div>
        </div>

        <div class="theory-stack">
          {
            theoryItems.map((item) => (
              <article class="theory-card" data-reveal>
                <strong>{item.title}</strong>
                <p>{item.body}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="visit-grid" id="visit">
        {
          visitItems.map((item) => (
            <article class="visit-card" data-reveal>
              <strong>{item.title}</strong>
              <p>{item.body}</p>
            </article>
          ))
        }
      </section>

      <section class="quote-band" data-reveal>
        <p class="quote-text">
          The piece is less a thing to decode than a set of conditions for paying attention.
        </p>
      </section>

      <p class="footer-note">
        Built in Astro so the site can grow from a QR landing page into a maintainable exhibition
        microsite with reusable content sections.
      </p>
    </main>
  </div>
</BaseLayout>
