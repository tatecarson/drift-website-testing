---
import BaseLayout from "../layouts/BaseLayout.astro";
import copy from "../data/copy.json";
import processItems from "../data/process.json";

const base = import.meta.env.BASE_URL;
---

<BaseLayout title={copy.meta.title} description={copy.meta.description}>
  <div class="page-shell">
    <header class="site-header">
      <div>
        <p class="site-kicker">{copy.header.kicker}</p>
        <p class="site-subtitle">{copy.header.subtitle}</p>
      </div>
      <nav class="section-nav" aria-label="Page sections">
        <a class="section-link" href="#overview">Overview</a>
        <a class="section-link" href="#process">Process</a>
        <a class="section-link" href="#theory">Theory</a>
        <a class="section-link" href="#visit">Visit</a>
      </nav>
    </header>

    <main>
      <section class="hero-grid" id="overview">
        <article class="intro-panel" data-reveal>
          <div>
            <span class="eyebrow">{copy.hero.eyebrow}</span>
            <h1 class="hero-title">{copy.hero.title}</h1>
          </div>
          <p class="intro-copy">{copy.hero.introCopy}</p>
          <div class="meta-row">
            {copy.hero.metaTags.map((tag) => <span>{tag}</span>)}
          </div>
        </article>

        <div class="stack">
          {
            copy.hero.noteCards.map((card) => (
              <article class="note-card" data-reveal>
                <strong>{card.title}</strong>
                <p>{card.body}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section-grid" id="process">
        <div data-reveal>
          <span class="eyebrow">{copy.process.eyebrow}</span>
          <h2 class="section-title">{copy.process.title}</h2>
          <div class="manifesto">
            <p>{copy.process.description}</p>
          </div>
        </div>

        <div class="image-rail">
          {
            processItems.map((item) => (
              <figure class="image-card" data-reveal>
                <img src={`${base}${item.image}`} alt={item.alt} />
                <figcaption class="image-caption">
                  <strong>{item.title}</strong>
                  <span>{item.caption}</span>
                </figcaption>
              </figure>
            ))
          }
        </div>
      </section>

      <section class="section-grid" id="theory">
        <div class="theory-stack">
          <div data-reveal>
            <span class="eyebrow">{copy.theory.eyebrow}</span>
            <h2 class="section-title">{copy.theory.title}</h2>
          </div>
          <div class="manifesto" data-reveal>
            <ul class="bullet-list">
              {copy.theory.bulletList.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </div>

        <div class="theory-stack">
          {
            copy.theory.cards.map((item) => (
              <article class="theory-card" data-reveal>
                <strong>{item.title}</strong>
                <p>{item.body}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="visit-grid" id="visit">
        {
          copy.visit.cards.map((item) => (
            <article class="visit-card" data-reveal>
              <strong>{item.title}</strong>
              <p>{item.body}</p>
            </article>
          ))
        }
      </section>

      <section class="quote-band" data-reveal>
        <p class="quote-text">{copy.quote.text}</p>
      </section>

      <p class="footer-note">{copy.footer.text}</p>
    </main>
  </div>

  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" aria-label="Close">&times;</button>
    <img class="lightbox-img" id="lightbox-img" src="" alt="" />
  </div>

  <script>
    const lightbox = document.getElementById("lightbox")!;
    const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;

    document.querySelectorAll<HTMLImageElement>(".image-card img").forEach((img) => {
      img.addEventListener("click", () => {
        lightboxImg.src = img.src;
        lightboxImg.alt = img.alt;
        lightbox.classList.add("is-active");
      });
    });

    lightbox.querySelector(".lightbox-close")!.addEventListener("click", () => {
      lightbox.classList.remove("is-active");
    });

    lightbox.addEventListener("click", (e) => {
      if (e.target === lightbox) {
        lightbox.classList.remove("is-active");
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        lightbox.classList.remove("is-active");
      }
    });
  </script>
</BaseLayout>
